# ============================================
# ARKAGRID - NEIGHBOURHOOD ENERGY TRADING PLATFORM
# Environment Configuration Template
# ============================================

# ============================================
# Backend (Server)
# ============================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arkagrid

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Platform Configuration
PLATFORM_FEE_PERCENT=2.5
DELIVERY_TIMEOUT_MINUTES=60

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id

# ==============================
# Solana Blockchain Configuration
# ==============================
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=PASTE_PROGRAM_ID_AFTER_DEPLOY
ARKAGRID_METER_AUTHORITY_KEYPAIR=./solana/keypairs/meter_authority.json
ARKAGRID_TREASURY_PUBKEY=PASTE_TREASURY_PUBKEY

# ============================================
# Frontend (Client)
# ============================================

# API Base URL
VITE_API_BASE_URL=http://localhost:5000/api

# Google Client ID (must match GOOGLE_CLIENT_ID above)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Solana Frontend
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# ============================================
# Notes
# ============================================
# 1. Generate secure secrets using:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 
# 2. Database setup:
#    - Install PostgreSQL locally or use Docker
#    - Create database: createdb arkagrid
#    - Run: npm run db:setup (from server directory)
#
# 3. Solana setup:
#    - Install Anchor CLI: https://www.anchor-lang.com/docs/installation
#    - Run: cd solana && npm install && npm run airdrop
#    - Build: anchor build
#    - Deploy: anchor deploy --provider.cluster devnet
#    - Run post-deploy: npm run simulate
#
# 4. For production:
#    - Use strong JWT secrets
#    - Set NODE_ENV=production
#    - Use secure database URL
#    - Enable HTTPS
#    - Switch SOLANA_NETWORK to mainnet
