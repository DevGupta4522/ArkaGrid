# Solana Config
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_MAINNET_RPC_URL=https://solana-mainnet.rpcpool.com/YOUR_KEY
PROGRAM_ID=YOUR_PROGRAM_ID_AFTER_DEPLOY

# ArkaGrid Wallets
ARKAGRID_AUTHORITY_KEYPAIR=./keypairs/authority.json
ARKAGRID_METER_AUTHORITY_KEYPAIR=./keypairs/meter_authority.json
ARKAGRID_TREASURY_PUBKEY=YOUR_TREASURY_WALLET_ADDRESS
ARKAGRID_FEE_BPS=250

# Backend
ARKAGRID_BACKEND_KEYPAIR=./keypairs/backend.json
